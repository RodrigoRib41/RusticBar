generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ReservationStatus {
  pending
  confirmed
  canceled
}

enum MenuCategory {
  comida
  bebida
  postre
  promo
}

model Reservation {
  id              String            @id @default(uuid()) @db.Uuid
  name            String
  phone           String
  date            DateTime          @default(dbgenerated("CURRENT_DATE")) @db.Date
  time            String            @default("21:00")
  people          Int
  userEmail       String?
  ipAddress       String?
  status          ReservationStatus @default(confirmed)
  token           String?           @unique
  tokenExpiration DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  userId          String?           @db.Uuid
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([createdAt])
  @@index([ipAddress])
  @@index([phone])
  @@index([status])
  @@index([status, date])
  @@index([tokenExpiration])
  @@index([userEmail])
  @@index([userId])
  @@index([userId, date])
}

model ReservationDayCapacity {
  id        String   @id @default(uuid()) @db.Uuid
  date      DateTime @unique @db.Date
  capacity  Int      @default(40)
  enabled   Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([enabled])
}

model EnabledReservationDay {
  id        String   @id @default(uuid()) @db.Uuid
  dayOfWeek Int      @unique
  enabled   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

model User {
  id            String        @id @default(uuid()) @db.Uuid
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  googleId      String?       @unique
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  accounts      Account[]
  reservations  Reservation[]
  sessions      Session[]

  @@index([email])
  @@index([googleId])
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model BlockedEmail {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  reason    String?  @db.Text
  blockedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([email])
}

model HomeGalleryImage {
  id            String   @id @default(uuid()) @db.Uuid
  imageUrl      String   @db.Text
  imagePublicId String
  alt           String?
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sortOrder])
  @@index([createdAt])
}

model Pedido {
  id          String       @id @default(uuid()) @db.Uuid
  mesa        Int
  customerName String      @default("Cliente")
  estado      String       @default("pendiente")
  total       Float
  completedAt DateTime?
  createdAt   DateTime     @default(now())

  items PedidoItem[]

  @@index([mesa])
  @@index([mesa, estado])
  @@index([estado])
  @@index([completedAt])
  @@index([createdAt])
}

model PedidoItem {
  id       String @id @default(uuid()) @db.Uuid
  pedidoId String @db.Uuid
  nombre   String
  precio   Float
  cantidad Int

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
}

model BarDailyRevenue {
  id           String   @id @default(uuid()) @db.Uuid
  date         DateTime @unique @db.Date
  total        Float    @default(0)
  closedTables Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
}

model RestaurantTable {
  id        String   @id @default(uuid()) @db.Uuid
  number    Int      @unique
  token     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([token])
  @@index([active])
}

model OrderSignal {
  id        String   @id @default(uuid()) @db.Uuid
  type      String
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model MenuSubcategory {
  id        String       @id @default(uuid()) @db.Uuid
  name      String
  slug      String
  category  MenuCategory
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  items     MenuItem[]

  @@unique([category, slug])
  @@index([category])
  @@index([sortOrder])
}

model MenuItem {
  id             String           @id @default(uuid()) @db.Uuid
  title          String
  description    String           @db.Text
  priceCents     Int
  category       MenuCategory
  subcategoryId  String?          @db.Uuid
  imageUrl       String?          @db.Text
  imagePublicId  String?
  active         Boolean          @default(true)
  deletedAt      DateTime?
  sortOrder      Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  subcategory    MenuSubcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)

  @@index([active])
  @@index([category])
  @@index([deletedAt])
  @@index([subcategoryId])
  @@index([sortOrder])
}
